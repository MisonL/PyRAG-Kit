# 将此文件复制为 .env 后，再填入实际密钥。
# 非密钥类配置请放在 config.toml。

# 聊天模型或 OpenAI 兼容渠道
OPENAI_API_KEY="sk-your-openai-compatible-key"
OPENAI_API_BASE="https://api.openai.com/v1"
DEFAULT_LLM_PROVIDER="openai"

# 其他可选模型密钥
ANTHROPIC_API_KEY=""
GOOGLE_API_KEY=""
SILICONFLOW_API_KEY=""
QWEN_API_KEY=""
VOLC_ACCESS_KEY=""
VOLC_SECRET_KEY=""
JINA_API_KEY=""
DEEPSEEK_API_KEY=""
GROK_API_KEY=""

# 本地覆盖项
# 默认嵌入模型已在 config.toml 中设置为 local-hash。
# 如需切换，请在这里覆盖 DEFAULT_EMBEDDING_PROVIDER 或在 config.toml 中修改。
# DEFAULT_EMBEDDING_PROVIDER="local-hash"

# iflow 示例
# OPENAI_API_KEY="sk-your-iflow-key"
# OPENAI_API_BASE="https://apis.iflow.cn/v1"
# DEFAULT_LLM_PROVIDER="iflow-qwen3-max"
